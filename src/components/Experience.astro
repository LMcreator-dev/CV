---
import SectionHeading from "./ui/SectionHeading.astro";

interface ExperienceRow {
  company: string;
  position: string;
  period: string;
  start: string;
  end: string;
  description: string;
  highlights: string[];
  subItems?: TimelineSubItem[];
}

interface EducationRow {
  institution: string;
  title: string;
  period: string;
  start: string;
  end: string;
  location?: string;
  details: string[];
}

interface TimelineSubItem {
  title: string;
  period: string;
  start: string;
  end: string;
  description: string;
}

interface Props {
  title: string;
  experiences: ExperienceRow[];
  education: EducationRow[];
}

type TimelineItem = {
  kind: "experience" | "education";
  period: string;
  start: string;
  title: string;
  organization: string;
  description?: string;
  location?: string;
  details: string[];
  subItems: TimelineSubItem[];
};

type TimelineRow =
  | {
      type: "year";
      year: string;
    }
  | {
      type: "entry";
      item: TimelineItem;
    };

const { title, experiences, education } = Astro.props;

const toMonthIndex = (value: string) => {
  const [year, month] = value.split("-").map(Number);

  return year * 12 + month - 1;
};

const timelineItems: TimelineItem[] = [
  ...experiences.map((item) => ({
    kind: "experience" as const,
    period: item.period,
    start: item.start,
    title: item.position,
    organization: item.company,
    description: item.description,
    details: item.highlights,
    subItems: [...(item.subItems ?? [])].sort((a, b) => toMonthIndex(a.start) - toMonthIndex(b.start)),
  })),
  ...education.map((item) => ({
    kind: "education" as const,
    period: item.period,
    start: item.start,
    title: item.title,
    organization: item.institution,
    location: item.location,
    details: item.details,
    subItems: [],
  })),
].sort((a, b) => toMonthIndex(a.start) - toMonthIndex(b.start));

const timelineRows: TimelineRow[] = [];
let currentYear = "";

for (const item of timelineItems) {
  const itemYear = item.start.slice(0, 4);

  if (itemYear !== currentYear) {
    timelineRows.push({
      type: "year",
      year: itemYear,
    });

    currentYear = itemYear;
  }

  timelineRows.push({
    type: "entry",
    item,
  });
}
---

<section class="section" id="experience">
  <div class="container">
    <SectionHeading
      title={title}
      intro="Vista cronológica combinando formación técnica y experiencia profesional."
      eyebrow="Trayectoria"
    />
    <div class="career-legend" aria-label="Leyenda de trayectoria">
      <span><i class="legend-dot legend-dot-study"></i>Estudios</span>
      <span><i class="legend-dot legend-dot-work"></i>Experiencia</span>
    </div>
    <div class="career-timeline">
      {timelineRows.map((row) =>
        row.type === "year" ? (
          <div class="career-year-row">
            <span class="career-year">{row.year}</span>
          </div>
        ) : (
          <article class={`career-entry career-entry-${row.item.kind}`}>
            {row.item.kind === "education" ? (
              <>
                <div class="card career-card career-card-education">
                  <p class="timeline-period">{row.item.period}</p>
                  <p class="career-type career-type-education">Estudios</p>
                  <h3>{row.item.title}</h3>
                  <p class="timeline-company">{row.item.organization}</p>
                  {row.item.location && <p class="career-location">{row.item.location}</p>}
                  <ul>
                    {row.item.details.map((detail) => (
                      <li>{detail}</li>
                    ))}
                  </ul>
                </div>
                <div class="career-rail" aria-hidden="true">
                  <div class="career-marker career-marker-education"></div>
                </div>
                <div class="career-empty"></div>
              </>
            ) : (
              <>
                <div class="career-empty"></div>
                <div class="career-rail" aria-hidden="true">
                  <div class="career-marker career-marker-experience"></div>
                </div>
                <div class="card career-card career-card-experience">
                  <p class="timeline-period">{row.item.period}</p>
                  <p class="career-type career-type-experience">Experiencia</p>
                  <h3>{row.item.title}</h3>
                  <p class="timeline-company">{row.item.organization}</p>
                  {row.item.description && <p>{row.item.description}</p>}
                  {row.item.subItems.length > 0 ? (
                    <div class="workstream-list" aria-label={`Trabajos dentro de ${row.item.organization}`}>
                      {row.item.subItems.map((subItem) => (
                        <article class="workstream-item">
                          <p>{subItem.period}</p>
                          <h4>{subItem.title}</h4>
                          <span>{subItem.description}</span>
                        </article>
                      ))}
                    </div>
                  ) : (
                    <ul>
                      {row.item.details.map((detail) => (
                        <li>{detail}</li>
                      ))}
                    </ul>
                  )}
                </div>
              </>
            )}
          </article>
        ),
      )}
    </div>
  </div>
</section>
