---
import SectionHeading from "./ui/SectionHeading.astro";
import SkillCard from "./ui/SkillCard.astro";

interface Knowledge {
  name: string;
  level: 1 | 2 | 3 | 4;
  description: string;
}

interface Props {
  title: string;
  knowledge: Knowledge[];
}

const { title, knowledge } = Astro.props;
const sortedKnowledge = [...knowledge].sort((a, b) => a.name.localeCompare(b.name, "es"));
---

<section class="section section-alt" id="skills">
  <div class="container">
    <SectionHeading
      title={title}
      intro="Conocimientos técnicos y operativos ordenados alfabéticamente, con nivel visual por barras."
      align="center"
      eyebrow="Conocimientos"
    />
    <div class="grid skills-grid">
      {sortedKnowledge.map((item) => (
        <SkillCard {...item} />
      ))}
    </div>
  </div>
</section>
