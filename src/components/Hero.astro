---
interface Props {
  title: string;
  role: string;
  subtitle: string;
  ctaPrimary?: string;
  ctaSecondary?: string;
  location: string;
  profileImage?: string;
}

const {
  title,
  role,
  subtitle,
  ctaPrimary = "Ver experiencia",
  ctaSecondary = "Ir a contacto",
  location,
  profileImage,
} = Astro.props;

const profileInitials = title
  .split(" ")
  .filter(Boolean)
  .slice(0, 2)
  .map((part) => part[0]?.toUpperCase() ?? "")
  .join("");
---

<section class="hero" id="inicio">
  <div class="container hero-grid">
    <div>
      <h1>{title}</h1>
      <p class="hero-role">{role}</p>
      <p class="hero-subtitle">{subtitle}</p>
      <div class="hero-actions">
        <a class="button button-primary" href="#experience">{ctaPrimary}</a>
        <a class="button button-secondary" href="#contact">{ctaSecondary}</a>
      </div>
    </div>
    <aside class="hero-highlight" aria-label="Ubicación y foco profesional">
      <div class="hero-profile">
        {profileImage ? (
          <a
            class="hero-profile-link"
            href={profileImage}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`Abrir foto de perfil de ${title} en tamaño completo`}
          >
            <img
              src={profileImage}
              alt={`Foto de perfil de ${title}`}
              loading="eager"
              decoding="async"
            />
          </a>
        ) : (
          <span class="hero-profile-fallback" aria-hidden="true">{profileInitials}</span>
        )}
      </div>
      <strong>+4 años</strong>
      <p>Experiencia técnica en sistemas, monitorización y operaciones.</p>
      <p>
        <strong>{location}</strong>
      </p>
    </aside>
  </div>
</section>
