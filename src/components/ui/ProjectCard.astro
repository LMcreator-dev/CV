---
interface Props {
  title: string;
  description: string;
  image: string;
  technologies: string[];
  link?: string;
}

const { title, description, image, technologies, link } = Astro.props;
---

<article class="card project-card">
  {link ? (
    <a href={link} target="_blank" rel="noopener noreferrer" aria-label={`Abrir ${title}`}>
      <img src={image} alt={title} loading="lazy" />
    </a>
  ) : (
    <img src={image} alt={title} loading="lazy" />
  )}
  <div class="project-body">
    <h3>
      {link ? (
        <a href={link} target="_blank" rel="noopener noreferrer">
          {title}
        </a>
      ) : (
        title
      )}
    </h3>
    <p>{description}</p>
    <ul class="tag-list" aria-label={`Tecnologías de ${title}`}>
      {technologies.map((tech) => (
        <li>{tech}</li>
      ))}
    </ul>
    {link && (
      <a href={link} target="_blank" rel="noopener noreferrer" class="button button-link">
        Ver demo
      </a>
    )}
  </div>
</article>
