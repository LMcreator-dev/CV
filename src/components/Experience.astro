---
import SectionHeading from "./ui/SectionHeading.astro";
import ExperienceItem from "./ui/ExperienceItem.astro";

interface ExperienceRow {
  company: string;
  position: string;
  period: string;
  description: string;
  highlights: string[];
}

interface Props {
  title: string;
  experiences: ExperienceRow[];
}

const { title, experiences } = Astro.props;
---

<section class="section" id="experience">
  <div class="container">
    <SectionHeading
      title={title}
      intro="Experiencia en entornos de operación con foco en impacto real."
      eyebrow="Trayectoria"
    />
    <div class="timeline">
      {experiences.map((exp) => (
        <ExperienceItem {...exp} />
      ))}
    </div>
  </div>
</section>
