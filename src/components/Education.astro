---
import SectionHeading from "./ui/SectionHeading.astro";

interface EducationRow {
  institution: string;
  title: string;
  period: string;
  location?: string;
  details: string[];
}

interface Props {
  title: string;
  education: EducationRow[];
}

const { title, education } = Astro.props;
---

<section class="section section-alt" id="education">
  <div class="container">
    <SectionHeading
      title={title}
      intro="Formación técnica en sistemas, telecomunicaciones, electricidad e instalaciones."
      eyebrow="Estudios"
      align="center"
    />
    <div class="grid education-grid">
      {education.map((item) => (
        <article class="card education-card">
          <p class="education-period">{item.period}</p>
          <h3>{item.title}</h3>
          <p class="education-institution">{item.institution}</p>
          {item.location && <p class="education-location">{item.location}</p>}
          <ul>
            {item.details.map((detail) => (
              <li>{detail}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
