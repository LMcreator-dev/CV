---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Certifications from '../components/Certifications.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import { certifications, education, experiences, knowledge, profile, projects } from '../data/cv';

const navItems = [
  { href: "#inicio", label: "Inicio" },
  { href: "#about", label: "Sobre mí" },
  { href: "#skills", label: "Conocimientos" },
  { href: "#experience", label: "Trayectoria" },
  { href: "#certifications", label: "Certificaciones" },
  { href: "#projects", label: "Proyectos" },
  { href: "#contact", label: "Contacto" },
];

const aboutStats = [
  { value: "+4", label: "Años en entorno técnico" },
  { value: "ASIR", label: "Formación principal" },
  { value: "B", label: "Carné y vehículo propio" },
  { value: "IT", label: "Sistemas, redes y automatización" },
];
---

<MainLayout title="Portfolio | Luis María Galindo García">
  <Header name={profile.name} navItems={navItems} />
  <main class="portfolio-track" data-horizontal-track>
    <Hero
      title={profile.name}
      role={profile.role}
      subtitle={profile.headline}
      location={profile.location}
    />
    <About title="Sobre mí" description={profile.summary} stats={aboutStats} />
    <Skills title="Conocimientos" knowledge={knowledge} />
    <Experience
      title="Trayectoria Profesional y Estudios"
      experiences={experiences}
      education={education}
    />
    <Certifications title="Certificaciones" certifications={certifications} />
    <Projects title="Proyectos Destacados" projects={projects} />
    <Contact
      title="Contacto"
      email={profile.email}
      phone={profile.phone}
      linkedin={profile.linkedin}
    />
  </main>
  <div class="panel-controls" aria-label="Navegación horizontal">
    <button class="panel-arrow" type="button" data-panel-prev aria-label="Sección anterior">
      <span aria-hidden="true">‹</span>
    </button>
    <nav class="panel-dots" aria-label="Secciones">
      {navItems.map((item) => (
        <a href={item.href} aria-label={item.label} data-dot-link></a>
      ))}
    </nav>
    <button class="panel-arrow" type="button" data-panel-next aria-label="Sección siguiente">
      <span aria-hidden="true">›</span>
    </button>
  </div>


  <script>
    const track = document.querySelector("[data-horizontal-track]");
    const panels = Array.from(document.querySelectorAll("[data-horizontal-track] > section"));
    const links = Array.from(document.querySelectorAll("[data-section-link], [data-dot-link]"));
    const hashLinks = Array.from(document.querySelectorAll('a[href^="#"]'));
    const prevButton = document.querySelector("[data-panel-prev]");
    const nextButton = document.querySelector("[data-panel-next]");
    const root = document.documentElement;
    const navbar = document.querySelector(".navbar");
    const panelModeBreakpoint = window.matchMedia("(max-width: 860px)");
    const reducedMotionPreference = window.matchMedia("(prefers-reduced-motion: reduce)");
    let wheelLock = false;
    let lastActiveId = "";

    const panelIndexByHash = new Map(
      panels.map((panel, index) => [`#${panel.id}`, index]),
    );

    const isVerticalPanels = () => panelModeBreakpoint.matches;
    const getMotionBehavior = () => (reducedMotionPreference.matches ? "auto" : "smooth");
    const syncLayoutMetrics = () => {
      const navHeight = Math.ceil(navbar?.getBoundingClientRect().height ?? 0);

      if (navHeight > 0) {
        root.style.setProperty("--nav-height", `${navHeight}px`);
      }
    };

    const getActiveIndex = () => {
      if (!track || panels.length === 0) return 0;

      if (!isVerticalPanels()) {
        return Math.round(track.scrollLeft / track.clientWidth);
      }

      const navHeight = navbar?.getBoundingClientRect().height ?? 0;
      let activeIndex = 0;
      let closestDistance = Number.POSITIVE_INFINITY;

      panels.forEach((panel, index) => {
        const distance = Math.abs(panel.getBoundingClientRect().top - navHeight - 12);
        if (distance < closestDistance) {
          closestDistance = distance;
          activeIndex = index;
        }
      });

      return activeIndex;
    };

    const setActive = () => {
      const activePanel = panels[getActiveIndex()];
      const activeId = activePanel?.id;
      if (!activeId || activeId === lastActiveId) return;

      lastActiveId = activeId;
      let activeTopLink = null;

      links.forEach((link) => {
        const isActive = link.getAttribute("href") === `#${activeId}`;
        link.toggleAttribute("aria-current", isActive);
        if (isActive && link.hasAttribute("data-section-link")) {
          activeTopLink = link;
        }
      });

      activeTopLink?.scrollIntoView({
        behavior: getMotionBehavior(),
        block: "nearest",
        inline: "center",
      });

      if (activeId && window.location.hash !== `#${activeId}`) {
        window.history.replaceState(null, "", `#${activeId}`);
      }
    };

    const scrollToPanelIndex = (index, behavior = "smooth") => {
      if (!track || panels.length === 0) return;
      const clampedIndex = Math.max(0, Math.min(panels.length - 1, index));
      const nextPanel = panels[clampedIndex];
      if (!nextPanel) return;

      if (isVerticalPanels()) {
        nextPanel.scrollIntoView({ behavior, block: "start" });
        return;
      }

      nextPanel.scrollTo({ top: 0, behavior: "auto" });
      track.scrollTo({ left: clampedIndex * track.clientWidth, behavior });
    };

    const goToPanel = (offset) => {
      if (panels.length === 0) return;
      scrollToPanelIndex(getActiveIndex() + offset, getMotionBehavior());
    };

    const goToPanelHash = (hash, behavior = "smooth") => {
      if (!panelIndexByHash.has(hash)) return false;

      const nextIndex = panelIndexByHash.get(hash);
      const resolvedBehavior = behavior === "smooth" ? getMotionBehavior() : behavior;
      scrollToPanelIndex(nextIndex, resolvedBehavior);
      return true;
    };

    const canScrollPanel = (panel, direction) => {
      if (!panel) return false;
      if (direction > 0) {
        return panel.scrollTop + panel.clientHeight < panel.scrollHeight - 2;
      }

      return panel.scrollTop > 2;
    };

    const handleWheelNavigation = (event) => {
      if (!track || panels.length === 0 || wheelLock || isVerticalPanels()) return;
      const delta = Math.abs(event.deltaY) >= Math.abs(event.deltaX) ? event.deltaY : event.deltaX;

      if (Math.abs(delta) < 18) return;

      const direction = delta > 0 ? 1 : -1;
      const activePanel = panels[getActiveIndex()];

      if (canScrollPanel(activePanel, direction)) return;

      event.preventDefault();
      wheelLock = true;
      goToPanel(direction);
      window.setTimeout(() => {
        wheelLock = false;
      }, 650);
    };

    prevButton?.addEventListener("click", () => goToPanel(-1));
    nextButton?.addEventListener("click", () => goToPanel(1));
    hashLinks.forEach((link) => {
      link.addEventListener("click", (event) => {
        if (isVerticalPanels()) return;
        const hash = link.getAttribute("href");
        if (!hash || !goToPanelHash(hash)) return;
        event.preventDefault();
        if (window.location.hash !== hash) {
          window.history.pushState(null, "", hash);
        }
        setActive();
      });
    });
    track?.addEventListener("wheel", handleWheelNavigation, { passive: false });
    track?.addEventListener("scroll", () => {
      if (isVerticalPanels()) return;
      window.requestAnimationFrame(setActive);
    }, { passive: true });
    window.addEventListener("scroll", () => {
      if (!isVerticalPanels()) return;
      window.requestAnimationFrame(setActive);
    }, { passive: true });
    window.addEventListener("resize", () => {
      syncLayoutMetrics();
      lastActiveId = "";
      if (!isVerticalPanels()) {
        goToPanelHash(window.location.hash, "auto");
      }
      window.requestAnimationFrame(setActive);
    });
    window.addEventListener("hashchange", () => {
      if (isVerticalPanels()) return;
      goToPanelHash(window.location.hash, "smooth");
    });
    if (typeof ResizeObserver !== "undefined") {
      const layoutObserver = new ResizeObserver(() => {
        syncLayoutMetrics();
      });

      if (navbar) {
        layoutObserver.observe(navbar);
      }
    }

    syncLayoutMetrics();

    if (isVerticalPanels()) {
      setActive();
    } else if (!goToPanelHash(window.location.hash, "auto")) {
      setActive();
    } else {
      window.requestAnimationFrame(setActive);
    }
  </script>
</MainLayout>
