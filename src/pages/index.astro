---
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Skills from '../components/Skills.astro';
import Experience from '../components/Experience.astro';
import Certifications from '../components/Certifications.astro';
import Projects from '../components/Projects.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';
import { certifications, experiences, profile, projects, skills } from '../data/cv';

const navItems = [
  { href: "#about", label: "Sobre mi" },
  { href: "#skills", label: "Skills" },
  { href: "#experience", label: "Experiencia" },
  { href: "#certifications", label: "Certificaciones" },
  { href: "#projects", label: "Proyectos" },
  { href: "#contact", label: "Contacto" },
];

const aboutStats = [
  { value: "+4", label: "Anos en IT tecnico" },
  { value: "3", label: "Bloques de especializacion" },
  { value: "Enterprise", label: "Contexto de proyectos" },
  { value: "24/7", label: "Mentalidad operativa" },
];
---

<MainLayout title="Portfolio | Luis María Galindo García">
  <Header name={profile.name} navItems={navItems} />
  <main>
    <Hero
      title={profile.name}
      role={profile.role}
      subtitle={profile.headline}
      location={profile.location}
    />
    <About title="Sobre mi" description={profile.summary} stats={aboutStats} />
    <Skills title="Habilidades Tecnicas" skills={skills} />
    <Experience title="Experiencia Profesional" experiences={experiences} />
  <Certifications title="Certificaciones" certifications={certifications} />
  <Projects title="Proyectos Destacados" projects={projects} />
    <Contact
      title="Contacto"
      email={profile.email}
      phone={profile.phone}
      linkedin={profile.linkedin}
    />
  </main>
  <Footer name={profile.name} />
</MainLayout>
